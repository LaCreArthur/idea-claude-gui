<idea-plugin>
    <id>com.lacrearthur.idea-claude-gui</id>
    <name>Claude GUI</name>
    <vendor>Arthur Scheidel</vendor>

    <description><![CDATA[
        <p><strong>Claude GUI</strong> — Embeds the <code>claude</code> CLI in a JetBrains TerminalView with native IDE UX on top.</p>
        <p>Full Sonnet 4.6 / Opus 4.6 access via Claude Max/Pro subscription — no API key required.</p>
        <ul>
            <li>Interactive Claude Code session in a tool window</li>
            <li>Native dialogs for interactive CLI prompts (AskUserQuestion, permissions, etc.)</li>
            <li>Send editor selection to Claude (Cmd+Alt+K)</li>
            <li>Slash command autocomplete</li>
        </ul>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow id="Claude"
                    anchor="right"
                    factoryClass="com.github.claudecodegui.ClaudeToolWindowFactory"
                    icon="/icons/cc-gui-icon.svg"
                    canCloseContents="false"/>
    </extensions>

    <actions>
        <action id="ClaudeCodeGUI.SendSelectionAction"
                class="com.github.claudecodegui.SendSelectionAction"
                text="Send to Claude"
                description="Send selected code to Claude input bar"
                icon="/icons/send-to-terminal.svg">
            <add-to-group group-id="EditorPopupMenu" anchor="first"/>
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt K"/>
            <keyboard-shortcut keymap="Mac OS X" first-keystroke="meta alt K"/>
            <keyboard-shortcut keymap="macOS" first-keystroke="meta alt K"/>
        </action>
    </actions>
</idea-plugin>
